# Choose one provider for local testing:
# template, gemini, openrouter, ollama, openai
AI_PROVIDER=template

# Gemini free-tier/local testing
# Get a key from https://aistudio.google.com/
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# OpenRouter free-model testing
# Get a key from https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-8b-instruct:free

# Local Ollama testing
# Install Ollama and run: ollama pull llama3.2
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# OpenAI paid/credit-based testing
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Local server
PORT=4173
